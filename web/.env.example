# Copy this to .env.local for local dev, or set in your deploy host's env vars.
# NOTHING here is required — every feature has a free / no-config default.

# ---- Database (libSQL / Turso) ----
# Local dev: defaults to file:./local.db if omitted (zero setup).
# Production (Vercel): create a free Turso DB at https://turso.tech and set both.
# DATABASE_URL=libsql://your-db-name.turso.io
# DATABASE_AUTH_TOKEN=eyJh...your-token...

# ---- AI copy generation ----
# We do NOT need a server-side key — AI copy is bring-your-own-key. Users paste
# their Anthropic key in the browser; it's stored in localStorage and proxied
# through /api/ai/generate without being logged.
#
# Only set ANTHROPIC_MODEL if you want to swap from the default sonnet 4.6.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Encryption secret (REQUIRED in production) ----
# 32+ byte hex string. Used to AES-256-GCM-encrypt the per-owner Resend keys
# (used by the welcome-email feature) before storing them in the DB.
# If you don't set this, an ephemeral key is generated per-process and
# encrypted values won't survive a restart. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WAITLISTKIT_SECRET=...

# ---- Site URL (for OG image absolute URLs) ----
# Vercel sets VERCEL_URL automatically. Override here if you have a custom domain.
# NEXT_PUBLIC_SITE_URL=https://drumroll.app

# ---- Billing: NOWPayments (crypto, required for real payments) ----
# Get keys at https://account.nowpayments.io. Works globally without LLC,
# accepts BTC/ETH/USDT and 300+ other coins, sub-1% transaction fees.
#
# Steps:
#   1. Settings → API Keys → copy the API key
#   2. Settings → Instant payment notifications → generate IPN secret
#   3. Same page: set Webhook URL to https://<your-domain>/api/billing/nowpayments/webhook
#   4. Settings → Payout wallets → add at least one (e.g. USDT TRC20)
#
# Without these, /api/billing/checkout runs in dev mode (flips the cookie
# owner's plan locally for 30 days) — useful for demos but no real money.
# NOWPAYMENTS_API_KEY=your-api-key
# NOWPAYMENTS_IPN_SECRET=your-ipn-secret
