# Copy this to .env.local for local dev, or set in your deploy host's env vars.
# Nothing here is required for the MVP to run — sane defaults are used.

# ---- Database (libSQL / Turso) ----
# Local dev: defaults to file:./local.db if omitted.
# Production (Vercel): create a free Turso DB at https://turso.tech and set both.
# DATABASE_URL=libsql://your-db-name.turso.io
# DATABASE_AUTH_TOKEN=eyJh...your-token...

# ---- AI copy generation (Anthropic Claude) ----
# Optional. If unset, copy-gen falls back to a deterministic template generator.
# Get a key at https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
